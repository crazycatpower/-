## LINE Bot 憑證（從 LINE Developers Console 取得）
# CHANNEL_ACCESS_TOKEN=
# CHANNEL_SECRET=

## PostgreSQL 連線字串（選填，無則不啟用 DB 功能）
# DATABASE_URL=postgresql://user:password@localhost:5432/dbname
# DB_RUN_MIGRATIONS=1
# DB_RUN_BACKFILL=0

## 預設圖片分析提示詞（選填）
# DEFAULT_ANALYZE_PROMPT=請分析目前畫面，重點說明可能的標誌、風險與建議行動。

## 公開網址（選填，空白則自動推算）
# PUBLIC_URL=

## YOLO 切片（tiling / SAHI）偵測（選填，皆有預設值）
# 切片總開關：設 0 完全關閉，維持原本單次整張推論
# YOLO_USE_SLICING=1
# 圖片長邊超過此像素才切片（小圖不切，避免多付推論成本）
# YOLO_SLICE_TRIGGER_SIDE=960
# 每個切片的寬高（像素）；SAHI 依圖片大小自動決定切幾塊
# YOLO_SLICE_SIZE=512
# 相鄰切片的重疊比例（0~1），避免物件被切在邊界而漏偵測
# YOLO_SLICE_OVERLAP=0.2
# 切片專用最小信心門檻（比整張推論嚴，過濾放大後的雜物誤判）；
# 遠處真人抓不到就調低（如 0.25），誤判太多就調高（如 0.35）
# YOLO_SLICE_MIN_CONF=0.3

## OpenAI（維持原本預設行為）
# OPENAI_API_KEY=sk-...
# （可選）若你仍想用 OpenAI 但指定不同模型：
# LLM_MODEL=gpt-4.1-mini

## Qwen3.5-9B（或任意 OpenAI 相容端點）
# LLM_BASE_URL=http://127.0.0.1:8000/v1
# LLM_API_KEY=EMPTY
# LLM_MODEL=qwen3.5-9b
#
# Qwen3.5-9B 若是「純文字」模型，請關閉視覺（不送圖片，只用 YOLO 摘要做回覆）
# LLM_SUPPORTS_VISION=false
#
# 若你部署的是「支援視覺」的相容模型/端點（例如 VL 模型），再開啟
# LLM_SUPPORTS_VISION=true
